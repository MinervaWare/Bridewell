#define PSIZE 256

vec4 palettize(vec4 color) {
	vec3 c = color.rgb;
	float bD = 1e6;
	vec3 bCol = c;
	int i;
	for(i=0;i<256;i+=4) {
		vec3 pc = palette[i]-c;
		float d = dot(pc,pc);
		if(d<bD) {bD=d;bCol=palette[i];}
		pc = palette[i+1]-c;
		d = dot(pc,pc);
		if(d<bD) {bD=d;bCol=palette[i+1];}	
		pc = palette[i+2]-c;
		d = dot(pc,pc);
		if(d<bD) {bD=d;bCol=palette[i+2];}
		pc = palette[i+3]-c;
		d = dot(pc,pc);
		if(d<bD) {bD=d;bCol=palette[i+3];}
	}
	return vec4(bCol, color.a);

}

