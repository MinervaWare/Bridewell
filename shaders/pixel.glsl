@ctype vec2 vec2

@vs vs_pixel

in vec2 ca_position;
in vec2 ca_texcoord;
out vec2 uv;

void main() {
	uv = ca_texcoord;
	gl_Position = vec4(ca_position,0.0,1.0);
}

@end

